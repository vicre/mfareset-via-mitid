{% load static %}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CAS Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{% static 'core/home.css' %}">
</head>
<body>

    <header class="site-header">
        <img src="{% static 'core/DTU_Logo.png' %}" alt="DTU" class="dtu-logo">
        <span class="site-header-title">Danmarks Tekniske Universitet</span>
        <div class="site-header-sep"></div>
        <span class="site-header-sub">MFA Self-Service</span>
    </header>

    <div class="page-content">
        <div class="card">
            <div class="card-inner">
                <div class="card-header">
                    <h1>CAS Profile</h1>
                </div>

                <div class="already-logged-in" style="align-items: flex-start; margin-bottom: 2rem;">
                    <span class="check-icon" style="margin-top: 2px; flex-shrink: 0;">✓</span>
                    <div>
                        <div>Logged in as <strong>{{ user.username }}</strong></div>
                        <div style="font-size: 0.85rem; color: #4a7c5c; margin-top: 0.3rem; font-weight: 400;">{{ resolved_upn }}</div>
                    </div>
                </div>

                <p class="section-title">Your current authentication methods</p>

                {% if messages %}
                    <div class="messages-stack">
                        {% for message in messages %}
                            <div class="message-box message-{{ message.tags|default:'info' }}">{{ message }}</div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if graph_error %}
                    <div class="error-box">
                        <strong>Could not load methods:</strong> {{ graph_error }}
                    </div>
                {% elif auth_methods %}
                    <ul class="methods-list">
                        {% for method in auth_methods %}
                            <li class="method-item">
                                <span class="method-dot"></span>
                                <div class="method-main">
                                    <div class="method-label">{{ method.label }}</div>
                                    {% if method.details %}
                                        <div class="method-details">{{ method.details }}</div>
                                    {% endif %}
                                </div>
                                <div class="method-side">
                                    {% if method.can_delete %}
                                        <form method="post" class="method-delete-form" data-method-label="{{ method.label }}">
                                            {% csrf_token %}
                                            <input type="hidden" name="method_id" value="{{ method.id }}">
                                            <label class="sr-only" for="confirm-{{ method.id }}">Type {{ method.label }} to confirm deletion</label>
                                            <input
                                                id="confirm-{{ method.id }}"
                                                type="text"
                                                name="confirmation_name"
                                                class="method-confirm-input"
                                                placeholder="Type {{ method.label }} to confirm"
                                                autocomplete="off"
                                                required
                                            >
                                            <button type="submit" class="method-delete-btn">Delete</button>
                                            <span class="method-delete-status" aria-live="polite">Attempting to delete MFA method</span>
                                        </form>
                                    {% else %}
                                        <span class="method-badge method-badge-static">Cannot be deleted</span>
                                    {% endif %}
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="no-methods">No authentication methods found.</p>
                {% endif %}

                <div class="action-row">
                    <a href="#" class="login-btn">Reset MFA →</a>
                    <a href="{% url 'cas_ng_logout' %}" class="logout-link">← Log out</a>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll(".method-delete-form").forEach((form) => {
            form.addEventListener("submit", () => {
                const methodItem = form.closest(".method-item");
                const requiredLabel = form.dataset.methodLabel || "";
                const input = form.querySelector(".method-confirm-input");
                const typedValue = input ? input.value.trim() : "";

                if (methodItem && typedValue === requiredLabel) {
                    methodItem.classList.add("is-deleting");
                }
            });
        });
    </script>

</body>
</html>
